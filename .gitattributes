# Auto-detect text files and normalize to LF in repo
* text=auto eol=lf

# Explicit text files (force LF regardless of OS)
*.md       text eol=lf
*.py       text eol=lf
*.js       text eol=lf
*.ts       text eol=lf
*.jsx      text eol=lf
*.tsx      text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.sh       text eol=lf
*.groovy   text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.sql      text eol=lf
*.cfg      text eol=lf
*.ini      text eol=lf
*.conf     text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows-only files keep CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary files (no diff, no EOL conversion)
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.pdf      binary
*.xlsx     binary
*.xls      binary
*.docx     binary
*.doc      binary
*.pptx     binary
*.ppt      binary
*.zip      binary
*.tar      binary
*.gz       binary
*.7z       binary
*.db       binary
*.sqlite   binary

# Boomi exports — text but explicit
*.xml      text eol=lf
